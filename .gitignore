# SWARAMA Agents — .gitignore
# Never commit secrets or runtime-generated files

# Secrets
config/.env.agents

# Runtime outputs (generated at runtime, not source code)
logs/
reports/
testing/regression/baseline_responses.json

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
